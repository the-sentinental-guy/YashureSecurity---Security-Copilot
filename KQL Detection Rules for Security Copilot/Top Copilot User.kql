let lookback = 30d;
let IdentityDim = IdentityInfo
    | summarize arg_max(TimeGenerated, *) by AccountUPN, AccountObjectId
    | extend UPN = tolower(trim(" ", tostring(AccountUPN))),
        ObjId = tostring(AccountObjectId),
        Dept = coalesce(tostring(Department), "Unmapped"),
        JobTitle = coalesce(tostring(JobTitle), "Unmapped"),
        DisplayName = coalesce(tostring(AccountDisplayName), tostring(AccountUPN))
    | project UPN, ObjId, Dept, JobTitle, DisplayName;
let CopilotBase = CopilotActivity
    | where TimeGenerated >= ago(lookback)
    | extend ActorUPN   = tolower(trim(" ", tostring(ActorName))),
        ActorObjId = tostring(ActorUserId)
    | join kind=leftouter (
        IdentityDim
        | project UPN, Dept, JobTitle, DisplayName) on $left.ActorUPN == $right.UPN
    | join kind=leftouter (
        IdentityDim
        | project ObjId, Dept2 = Dept, JobTitle2 = JobTitle, DisplayName2 = DisplayName) on $left.ActorObjId == $right.ObjId
    | extend Department = coalesce(Dept, Dept2, "Unmapped"),
        JobTitle = coalesce(JobTitle, JobTitle2, "Unmapped"),
        User = coalesce(DisplayName, DisplayName2, ActorUPN)
    | project TimeGenerated, User, Department, JobTitle;
CopilotBase | summarize CopilotEvents = count(),
    FirstSeen = min(TimeGenerated),
    LastSeen = max(TimeGenerated)
  by User, Department, JobTitle
| order by CopilotEvents desc, User asc
